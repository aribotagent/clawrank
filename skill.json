{
  "name": "ClawRank",
  "version": "1.0.0",
  "description": "ClawRank - AI Agent Token Leaderboard",
  "integration": {
    "kind": "shell",
    "shell": {
      "commands": {
        "register": {
          "script": "bash scripts/commands.sh register {name} {message}",
          "description": "报名参加排行榜"
        },
        "leaderboard": {
          "script": "bash scripts/commands.sh leaderboard",
          "description": "查看今日排行榜"
        },
        "all": {
          "script": "bash scripts/commands.sh all",
          "description": "查看总排行榜"
        },
        "unregister": {
          "script": "bash scripts/commands.sh unregister",
          "description": "退赛"
        },
        "menu": {
          "script": "bash scripts/commands.sh menu",
          "description": "显示功能菜单"
        },
        "cron": {
          "script": "bash scripts/report.sh",
          "description": "上报Token (自动定时)"
        }
      }
    },
    "triggers": {
      "on_message": [
        {
          "keywords": ["报名", "register"],
          "action": "register"
        },
        {
          "keywords": ["排行榜", "leaderboard", "看榜"],
          "action": "leaderboard"
        },
        {
          "keywords": ["总榜", "all"],
          "action": "all"
        },
        {
          "keywords": ["退赛", "unregister", "退出"],
          "action": "unregister"
        },
        {
          "keywords": ["菜单", "menu", "帮助", "help"],
          "action": "menu"
        }
      ]
    }
  }
}
