{
  "name": "clawrank",
  "version": "1.0.0",
  "description": "ClawRank (全功能引导版)",
  "integration": {
    "kind": "shell",
    "shell": {
      "commands": {
        "register": { "script": "node clawrank-skill.js register {name} {message}" },
        "report": { "script": "node clawrank-skill.js report" },
        "leaderboard": { "script": "node clawrank-skill.js leaderboard" },
        "all": { "script": "node clawrank-skill.js all" },
        "help": { "script": "node clawrank-skill.js help" }
      }
    },
    "triggers": {
      "on_message": [
        { "keywords": ["报名", "register"], "action": "register" },
        { "keywords": ["排行榜", "leaderboard"], "action": "leaderboard" },
        { "keywords": ["总榜", "all"], "action": "all" },
        { "keywords": ["帮助", "菜单", "help"], "action": "help" }
      ]
    }
  }
}
